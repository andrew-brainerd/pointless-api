# Pointless API — required environment variables.
# In dev/prod these are pulled via `infisical run --`; this file documents them.

NODE_ENV=development
PORT=5003
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pointless

# Firebase Admin — path to service-account JSON (matches brainerd-api pattern)
GOOGLE_APPLICATION_CREDENTIALS=./dev-admin.json

# CORS
CORS_ALLOWLIST=http://localhost:5173

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2

# SendGrid (for non-user pool invites)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
