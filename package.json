{
  "name": "pointless-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for Pointless — a points-betting app where small groups place virtual-points wagers. Spec: ../docs/specs/pointless.md",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "infisical run -- tsx watch src/server.ts",
    "dev:local": "tsx --env-file=.env.local watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "publish": "git push heroku HEAD -f",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pusher": "^5.3.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "mongodb-memory-server": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.0"
  }
}
